# Ignore version control directories and files
.git
.gitignore
.gitattributes
.svn
.hg

# Ignore Docker files (they are not needed inside the image)
Dockerfile
docker-compose.yml
docker-compose.*.yml
.dockerignore

# Ignore sensitive files
.env
.env.*
*.log
secrets/
*.key
*.pem

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore common temporary files and editor configs
*~
*.swp
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Ignore build output directories
build/
dist/
bin/

# Ignore documentation
docs/
README.md
LICENSE
